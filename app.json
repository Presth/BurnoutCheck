{
  "expo": {
    "name": "BurnoutCheck",
    "slug": "BurnoutCheck",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "burnoutcheck",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D6A4F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.burnoutcheck.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#2D6A4F"
      },
      "package": "com.peakspot.burnoutcheck.app",
      "edgeToEdgeEnabled": true,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-google-signin/google-signin",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#2D6A4F"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "439ba0cf-5185-452d-a00e-71896d7aa286"
      },
      "googleAuth": {
        "clientId": "376540875219-8hhhq6t0vtk5qn0aboasuunbbcpacjnb.apps.googleusercontent.com",
        "webClientId": "376540875219-8hhhq6t0vtk5qn0aboasuunbbcpacjnb.apps.googleusercontent.com"
      }
    },
    "owner": "peakspot"
  }
}
